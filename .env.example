# MediGuard Environment Variables Configuration
# ⚠️  IMPORTANT: DO NOT USE THESE VALUES IN PRODUCTION!
# Copy this file to .env and generate strong random secrets using:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ===== SERVICE PORTS =====
PORT=3001  # Can be overridden per service (3001=admin, 3003=patient, 3004=hospital, 3005=hospital-dash, 3006=pharmacy)

# ===== JWT SECRETS (CRITICAL - MUST BE SET IN PRODUCTION) =====
# ⚠️  NEVER use these example values in production!
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET_PATIENT=<generate-strong-random-secret-for-patient-portal>
JWT_SECRET_HOSPITAL=<generate-strong-random-secret-for-hospital-portal>
JWT_SECRET_ADMIN=<generate-strong-random-secret-for-admin-dashboard>
JWT_SECRET_PHARMACY=<generate-strong-random-secret-for-pharmacy-portal>

# ===== ENCRYPTION SECRETS (CRITICAL - MUST BE SET IN PRODUCTION) =====
# ⚠️  NEVER use these example values in production!
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_SECRET_EHR=<generate-strong-random-secret-for-ehr-encryption>
HOSPITAL_SCANNER_SECRET=<generate-strong-random-secret-for-qr-scanner>

# ===== CONTRACT RUNNER SECRET (CRITICAL) =====
# Used for request signing between applications and Contract Runner
CONTRACT_RUNNER_SECRET=<generate-strong-random-secret-32-chars-minimum>
CONTRACT_RUNNER_PORT=6000

# ===== HYPERLEDGER FABRIC NETWORK =====
# Peer node endpoint
FABRIC_PEER_URL=grpc://localhost:7051
# For TLS enabled Fabric networks:
# FABRIC_PEER_URL=grpcs://localhost:7051
FABRIC_PEER_DOMAIN=peer0.org1.example.com

# Certificate Authority endpoint
FABRIC_CA_URL=http://localhost:7054
# For TLS enabled Fabric networks:
# FABRIC_CA_URL=https://localhost:7054
FABRIC_CA_DOMAIN=ca.org1.example.com

# Orderer endpoint
FABRIC_ORDERER_URL=grpc://localhost:7050
# For TLS enabled Fabric networks:
# FABRIC_ORDERER_URL=grpcs://localhost:7050
FABRIC_ORDERER_DOMAIN=orderer.example.com

# Fabric network configuration
FABRIC_CHANNEL_NAME=mychannel
FABRIC_CHAINCODE_NAME=ehr-chaincode
FABRIC_MSP_ID=Org1MSP
FABRIC_ORG_NAME=Org1
FABRIC_ORG_DOMAIN=org1.example.com

# Fabric certificate and wallet configuration
FABRIC_ADMIN_USER=Admin@org1.example.com
FABRIC_WALLET_IDENTITY=appUser
FABRIC_CRYPTO_CONFIG_PATH=hyperledger-fabric/network/crypto-config
FABRIC_CERT_FILENAME=Admin@org1.example.com-cert.pem

# TLS configuration
ENABLE_TLS=true

# ===== OPTIONAL: VAULT/SECRET MANAGEMENT =====
# For production, use HashiCorp Vault or AWS Secrets Manager
# VAULT_ADDR=https://vault.example.com
# VAULT_TOKEN=your-vault-token
# AWS_SECRETSMANAGER_REGION=us-east-1

# ===== LOGGING =====
# DEBUG=mediguard:*
# LOG_LEVEL=info

# ===== NODE ENVIRONMENT =====
NODE_ENV=development
# Use 'production' for deployment

# ===== FEATURE FLAGS =====
# ENABLE_TLS=false  # Enable TLS for Fabric network
# USE_VAULT_SECRETS=false  # Use Vault for secret management
# USE_AUDIT_DATABASE=true  # Store audit logs in database

# ===== BCRYPT SETTINGS =====
BCRYPT_ROUNDS=10  # Number of salt rounds for bcrypt hashing

# ===== DEMO/FALLBACK ENTITY CONFIGURATION =====
# These are used as defaults when entity IDs are not provided
# Should ONLY be used in development environments
DEFAULT_HOSPITAL_ID=hospital-001
DEFAULT_PHARMACY_ID=pharmacy-001
DEFAULT_PATIENT_ID=patient-001
DEFAULT_HOSPITAL_NAME=City General Hospital
DEFAULT_PHARMACY_NAME=City Pharmacy

# ===== DEMO WALLET ADDRESSES (DEVELOPMENT ONLY) =====
# These demo wallets are used for testing and should not be used in production
DEMO_PATIENT_WALLET=0xFAB1234567890abcdef1234567890abcdef123456
DEMO_HOSPITAL_WALLET=0xFABa8f7e6d5c4b3a2918f7e6d5c4b3a291a8f7eh

# ===== INTER-SERVICE COMMUNICATION URLS =====
# URLs for cross-service API calls within the MediGuard ecosystem
ADMIN_DASHBOARD_URL=http://localhost:3001
PATIENT_PORTAL_URL=http://localhost:3003
HOSPITAL_PORTAL_URL=http://localhost:3004
HOSPITAL_DASHBOARD_URL=http://localhost:3005
PHARMACY_PORTAL_URL=http://localhost:3006

# ===== EXTERNAL SERVICE URLS =====
# ngrok API for tunnel management (optional, used in admin dashboard)
NGROK_API_URL=http://localhost:4040
NGROK_TUNNEL_URL=https://example.ngrok.io  # Your actual ngrok tunnel URL
# Before deploying to production:
# 1. Generate all secrets using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 2. Store secrets in secure vault (Vault, AWS Secrets Manager, Azure Key Vault, etc.)
# 3. Set NODE_ENV=production
# 4. Enable TLS/HTTPS (ENABLE_TLS=true)
# 5. Use real Fabric network endpoints (not localhost)
# 6. Enable audit logging and monitoring
# 7. Regular security audits and penetration testing
