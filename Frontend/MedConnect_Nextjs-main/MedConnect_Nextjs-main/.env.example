# MediGuard Frontend - Environment Variables
# Copy this file to .env.local and fill in the appropriate values

# ===== BACKEND SERVICE URLs =====
NEXT_PUBLIC_ADMIN_API=http://localhost:3001
NEXT_PUBLIC_PATIENT_API=http://localhost:3003
NEXT_PUBLIC_HOSPITAL_API=http://localhost:3005
NEXT_PUBLIC_PHARMACY_API=http://localhost:3006

# ===== CONTRACT RUNNER MICROSERVICE (SECURE GATEWAY) =====
NEXT_PUBLIC_CONTRACT_RUNNER_API=http://localhost:6000

# ===== ENVIRONMENT =====
NEXT_PUBLIC_APP_ENV=development

# ===== DEFAULT ENTITY CONFIGURATION =====
# These are demo/default entities used for testing
# Should be updated with actual entity IDs from the blockchain/database
NEXT_PUBLIC_DEFAULT_HOSPITAL_ID=hospital-001
NEXT_PUBLIC_DEFAULT_PHARMACY_ID=pharmacy-001
NEXT_PUBLIC_DEFAULT_PATIENT_ID=patient-001

# ===== DEFAULT WALLET ADDRESSES (DEMO ONLY) =====
# These wallet addresses are for testing and demo purposes
# Production environments should use real wallet addresses from user authentication
NEXT_PUBLIC_DEFAULT_HOSPITAL_WALLET=0xFABa8f7e6d5c4b3a2918f7e6d5c4b3a291a8f7eh
NEXT_PUBLIC_DEFAULT_PHARMACY_WALLET=0xPHARa8f7e6d5c4b3a2918f7e6d5c4b3a291a8f7ph
NEXT_PUBLIC_DEFAULT_PATIENT_WALLET=0xFAB1234567890abcdef1234567890abcdef123456

# ===== PRODUCTION DEPLOYMENT NOTE =====
# For production, update all URLs to HTTPS and use your actual domains:
# NEXT_PUBLIC_ADMIN_API=https://your-admin-domain.com
# NEXT_PUBLIC_PATIENT_API=https://your-patient-domain.com
# NEXT_PUBLIC_HOSPITAL_API=https://your-hospital-domain.com
# NEXT_PUBLIC_PHARMACY_API=https://your-pharmacy-domain.com
# NEXT_PUBLIC_CONTRACT_RUNNER_API=https://your-contract-runner-domain.com
# NEXT_PUBLIC_APP_ENV=production
